# Supabase — obtener en app.supabase.com > Ajustes > Claves API
# URL base del proyecto (sin /rest/v1/)
NEXT_PUBLIC_SUPABASE_URL=
# Clave publicable (sb_publishable_...) — segura para el navegador (protegida por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clave secreta (sb_secret_...) — SOLO servidor. NUNCA commitear ni exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=
